{
    "name": "marko/core",
    "description": "Marko Framework Core",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
